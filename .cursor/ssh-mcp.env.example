# Copy to ssh-mcp.env (gitignored) and fill in for the ssh-mcp MCP server.
# Used by .cursor/scripts/ssh-mcp.sh — see .cursor/skills/ssh-mcp/SKILL.md

# Required
SSH_MCP_HOST=your-server.example.com
SSH_MCP_USER=forge

# Optional — use key OR password (key preferred)
SSH_MCP_PORT=22
# SSH_MCP_KEY=/Users/you/.ssh/id_ed25519
# SSH_MCP_PASSWORD=

# Optional — sudo-exec tool (omit password if passwordless sudo)
# SSH_MCP_SUDO_PASSWORD=
# SSH_MCP_SU_PASSWORD=

# Optional — defaults match ssh-mcp upstream
# SSH_MCP_TIMEOUT=120000
# SSH_MCP_MAX_CHARS=none
# SSH_MCP_DISABLE_SUDO=1
