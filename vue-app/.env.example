# API host is hardcoded to https://push-service.test (see src/config/env.ts).
# During `npm run dev`, requests go through the Vite proxy with TLS verify off.

# Firebase (required for PWA / web push)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
